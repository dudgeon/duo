node_modules/
out/
dist/
*.tsbuildinfo

# macOS
.DS_Store
*.pem

# Editor
.idea/
.vscode/settings.json
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local

# Code-signing / notarization secrets — never commit
# Belt-and-suspenders: these files should live outside the repo entirely
# (~/.appstoreconnect/private_keys/*.p8 for the API key, Keychain for certs).
# These globs catch accidental drops into the working tree.
*.p8
*.p12
*.cer
*.mobileprovision
build/notarize-api-key.json

# Coverage
coverage/

# Stage 6: icon and entitlements files are generated before distribution
# build/icon.icns
# build/entitlements.mac.plist

# cli/duo is intentionally tracked — pre-built binary so Geoff can install
# without a build step. Regenerate with: npm run build:cli

# Claude Code workspace state — ignore per-user settings + worktrees,
# but track the shared `launch.json` (preview server config for the
# roadmap HTML, etc.)
.claude/*
!.claude/launch.json
