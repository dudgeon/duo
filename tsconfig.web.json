{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "types": ["vite/client"],
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": [
    "renderer/**/*",
    "shared/**/*"
  ],
  "exclude": ["node_modules"]
}
