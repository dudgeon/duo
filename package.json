{
  "name": "duo",
  "version": "0.1.0",
  "description": "macOS desktop app pairing Claude Code terminals with an embedded Chrome browser",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild",
    "build:cli": "esbuild cli/duo.ts --bundle --platform=node --outfile=cli/duo && chmod +x cli/duo",
    "build:all": "npm run build && npm run build:cli",
    "sync:claude": "mkdir -p ~/.claude/skills/duo/examples ~/.claude/agents && cp skill/SKILL.md ~/.claude/skills/duo/SKILL.md && cp skill/examples/*.md ~/.claude/skills/duo/examples/ && cp agents/duo-browser.md ~/.claude/agents/duo-browser.md && echo 'Synced skill + subagent to ~/.claude/'",
    "pack": "npm run build:all && electron-builder --dir",
    "dist": "npm run build:all && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint ."
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "node-pty": "^1.0.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.4.0",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.21.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
